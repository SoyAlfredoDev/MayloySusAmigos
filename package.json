{
  "name": "mailo-y-sus-amigos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "medusa:install": "cd medusa-backend && npm install",
    "medusa:dev": "cd medusa-backend && npm run dev",
    "medusa:backend": "cd medusa-backend && npm run backend:dev",
    "medusa:storefront": "cd medusa-backend && npm run storefront:dev",
    "medusa:migrate": "cd medusa-backend/apps/backend && npx medusa db:migrate",
    "medusa:admin-user": "cd medusa-backend/apps/backend && npx medusa user -e admin@mailoyusamigos.cl -p MailoAdmin2026!",
    "medusa:setup": "npm run medusa:migrate && npm run medusa:admin-user",
    "medusa:seed-catalog": "cd medusa-backend/apps/backend && npx medusa exec ./src/scripts/seed-pet-catalog.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@medusajs/js-sdk": "^2.15.5",
    "@medusajs/types": "^2.15.5",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
